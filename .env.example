# Copy to .env and fill in. Secrets are read only from the environment (never committed).

# OpenRouteService API key (walking-route measurement)
ROUTING_API_KEY=

# Optional provider endpoint overrides (defaults target public Overpass / Nominatim / ORS)
PLACES_BASE_URL=https://overpass-api.de/api/interpreter
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
ROUTING_BASE_URL=https://api.openrouteservice.org

LOG_LEVEL=info

# Set to 1 to wire deterministic fixture adapters instead of real providers (used by tests).
APTSCORE_TEST_MODE=0
